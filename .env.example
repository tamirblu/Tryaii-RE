# TryAii-DRE Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API key (required for active routing - calling models)
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenAI API key (optional - only if using OpenAI embeddings instead of local)
# OPENAI_API_KEY=sk-your-key-here

# HuggingFace token (optional - silences download warnings)
# HF_TOKEN=hf_your-token-here

# Custom embedding model (optional - defaults to all-MiniLM-L6-v2)
# TRYAII_DRE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Custom data directory (optional - defaults to ~/.tryaii_dre/)
# TRYAII_DRE_DATA_DIR=/path/to/data
